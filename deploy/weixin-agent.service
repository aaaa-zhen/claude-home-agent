[Unit]
Description=weixin-agent main service
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=6

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/weixin-agent
ExecStart=/home/ubuntu/weixin-agent/start.sh
Restart=always
RestartSec=10
User=ubuntu
EnvironmentFile=/home/ubuntu/weixin-agent/.env
Environment=TZ=Asia/Shanghai
KillMode=control-group
TimeoutStopSec=10
SendSIGKILL=yes
NoNewPrivileges=true

StandardOutput=journal
StandardError=journal
SyslogIdentifier=weixin-agent

[Install]
WantedBy=multi-user.target
