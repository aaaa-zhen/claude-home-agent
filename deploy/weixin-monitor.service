[Unit]
Description=weixin-agent monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/weixin-agent
ExecStart=/home/ubuntu/weixin-agent/venv/bin/python /home/ubuntu/weixin-agent/monitor.py
Restart=always
RestartSec=10
User=ubuntu
EnvironmentFile=/home/ubuntu/weixin-agent/.env

StandardOutput=journal
StandardError=journal
SyslogIdentifier=weixin-monitor

[Install]
WantedBy=multi-user.target
