# Home Assistant (via Cloudflare Tunnel)
HA_URL=https://your-ha-domain.example.com/api
HA_TOKEN=your_ha_long_lived_access_token

# Home Assistant SSH (via Cloudflare Tunnel or VPN)
HA_SSH_HOST=your-ha-domain.example.com
HA_SSH_PORT=22
HA_SSH_USER=root
HA_SSH_PASS=changeme

# Amap (Gaode) API
AMAP_KEY=your_amap_key

# Cloudflare Tunnel health check URL
TUNNEL_URL=https://your-ha-domain.example.com
